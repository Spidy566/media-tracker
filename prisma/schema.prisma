generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WatchStatus {
  PLAN_TO_WATCH
  WATCHING
  COMPLETED
  DROPPED
  ON_HOLD
}

model Movie {
  id        String   @id @default(cuid())

  // Cached data from TMDB, so we don't refetch every time
  tmdbId    Int      @unique
  title     String
  posterPath String?
  releaseDate DateTime?
  overview  String?

  // Your personal tracking data
  status    WatchStatus @default(PLAN_TO_WATCH)
  rating    Int?        // e.g. 1-10, nullable until you rate it
  notes     String?
  startedAt DateTime?
  finishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}